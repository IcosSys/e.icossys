# ===========================================
# e.IcosSys — Variables d'environnement
# ===========================================
# Copiez ce fichier en .env.local et remplissez les valeurs
# NE JAMAIS commiter le fichier .env.local !

# --- Administration ---
ADMIN_EMAIL=admin@boutique.com
ADMIN_PASSWORD=changez_ce_mot_de_passe

# --- Stripe Connect ---
# Clé secrète de la plateforme (obligatoire pour l'échange OAuth)
STRIPE_SECRET_KEY=sk_test_...

# Client ID Stripe Connect (Stripe Dashboard → Connect → Settings)
STRIPE_CLIENT_ID=ca_...

# URL de base du site (pour les callbacks OAuth Stripe)
NEXT_PUBLIC_BASE_URL=https://votre-domaine.vercel.app