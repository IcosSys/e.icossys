# ===========================================
# e.IcosSys — Variables d'environnement
# ===========================================
# Copiez ce fichier en .env.local et remplissez les valeurs
# NE JAMAIS commiter le fichier .env.local !

# --- Administration ---
ADMIN_EMAIL=admin@boutique.com
ADMIN_PASSWORD=changez_ce_mot_de_passe

# --- Stripe ---
# Clé publique (côté client, pas secrète)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Clé secrète (côté serveur UNIQUEMENT)
STRIPE_SECRET_KEY=sk_test_...

# --- Boutique ---
# Nom de la boutique (affiché sur le site)
NEXT_PUBLIC_SHOP_NAME=Ma Boutique